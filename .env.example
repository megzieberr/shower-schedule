# ------------------------------------------------------------
# Example environment file.
#
# These THREE values are safe to be public:
#   - the Supabase URL and anon key are protected by Row Level Security
#   - the VAPID *public* key is meant to live in the browser
#
# The SECRET keys (VAPID private key, service role key) are NEVER in here
# and NEVER in the repo. They live only inside Supabase.
#
# For local testing on your own computer: copy this file to ".env.local"
# and fill in the real values. (.env.local is git-ignored, so it stays private.)
# ------------------------------------------------------------

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
